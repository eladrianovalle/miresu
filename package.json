{
  "name": "miresu",
  "version": "0.1.0",
  "description": "miresu — fork-your-own portfolio site + aligned resume. Next.js 16 + Git-based content, build-time ATS PDF, JSON Resume export, dev-only /admin editor, GitHub Pages static export.",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build:resume-pdf": "tsx scripts/build-resume-pdf.tsx",
    "build:resume-json": "tsx scripts/build-resume-json.tsx",
    "build:resume": "npm run build:resume-pdf && npm run build:resume-json",
    "build": "npm run build:resume && next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings=0",
    "validate:content": "tsx scripts/validate-content.ts",
    "build:staging": "npm run build:resume && cross-env NEXT_EXPORT=1 next build && tsx scripts/move-export.ts",
    "test:e2e": "playwright test --project=desktop",
    "test:visual": "playwright test --project=visual",
    "test:a11y": "playwright test --project=accessibility",
    "playwright:install": "playwright install",
    "lint:styling-audit": "tsx scripts/lint-styling-audit.ts",
    "check:store-links": "tsx scripts/check-store-links.ts",
    "test": "vitest run"
  },
  "keywords": ["portfolio", "resume", "nextjs", "static-export", "json-resume"],
  "author": "Adriano Valle Hernandez",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.1",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "framer-motion": "^12.23.24",
    "next": "^16.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.1.12"
  }
}
